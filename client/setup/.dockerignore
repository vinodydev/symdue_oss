# .dockerignore for Client

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
*.local

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
coverage/
.nyc_output/
__tests__/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Setup folder (not needed in container)
setup/

