# Flowgraph backend environment template.
#
# DO NOT commit `.env` (it is in .gitignore). Run `setup/run.sh` to bootstrap
# a real .env from this template with random secrets generated for you.
#
# The substrate REFUSES TO START if any of these is left at its placeholder
# value (see flowgraph_oss/server/config/settings.py::assert_real_secrets).

# Database — POSTGRES_PASSWORD must be set; suggested: openssl rand -base64 32
DATABASE_URL=postgresql://graphmind:<set-via-setup-or-environment>@localhost:5433/graphmind_db
POSTGRES_USER=graphmind
POSTGRES_PASSWORD=<set-via-setup-or-environment>
POSTGRES_DB=graphmind_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=graphmind

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Security — SECRET_KEY must be set; suggested: openssl rand -hex 32
SECRET_KEY=<run: openssl rand -hex 32>

# Event scripts (interval / cron / queue / webhook scheduled Python).
# DEFAULT: disabled. Enabling executes user-supplied Python in the backend
# process — combined with the Docker socket mount this is host-root.
# DO NOT enable on a network-reachable deployment without auth in front.
# See SECURITY.md and docs/scheduling.md.
EVENT_SCRIPTS_ENABLED=false

# Docker (DooD configuration)
DOCKER_HOST=unix:///var/run/docker.sock
HOST_WORKSPACE_ROOT=/opt/graphmind/workspaces
INTERNAL_WORKSPACE_ROOT=/app/workspaces
HOST_CACHE_ROOT=/opt/graphmind/cache
INTERNAL_CACHE_ROOT=/app/cache
HOST_STORAGE_ROOT=/opt/graphmind/storage
INTERNAL_STORAGE_ROOT=/app/storage

# File storage
STORAGE_ROOT=/app/storage
STORAGE_URL_PREFIX=/api/files
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_FORMATS=png,jpg,jpeg,gif,webp

# MinIO — also set in docker-compose.yml; suggested values from setup/run.sh
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=<set-via-setup-or-environment>

# LLM provider keys — set as needed
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
